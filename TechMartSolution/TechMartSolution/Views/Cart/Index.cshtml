@model IEnumerable<TechMart.Domain.Entities.Product>
@{
    ViewData["Title"] = "TechMart - Products";
}

<div class="container mt-4">
    <h1 class="text-center mb-4">Welcome to TechMart</h1>

    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @* <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;"> *@
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted">@product.Description</p>
                        <h6 class="mt-auto text-primary">$@product.Price</h6>
                        <p class="small text-secondary">In Stock: @product.StockQuantity</p>

                        @if (product.StockQuantity > 0)
                        {
                            <a asp-action="Add" asp-route-id="@product.Id" class="btn btn-primary mt-2">
                                <i class="bi bi-cart-plus"></i> Add to Cart
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary mt-2" disabled>Out of Stock</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>