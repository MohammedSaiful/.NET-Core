@model List<TechMart.Domain.Entities.CartItem>
@{
    ViewData["Title"] = "Your Shopping Cart";
}

<h2>Shopping Cart</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Product.Name</td>
                <td>$@item.Product.Price</td>
                <td>@item.Quantity</td>
                <td>$@(item.Quantity* item.Product.Price)</td>
                <td>
                    <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Remove</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="text-end">
    <h4>Subtotal: $@ViewBag.Total</h4>
    <a asp-controller="Checkout" asp-action="Index" class="btn btn-success">Proceed to Checkout</a>
</div>