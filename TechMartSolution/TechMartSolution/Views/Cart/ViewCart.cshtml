@model List<TechMart.Domain.Entities.CartItem>
@{
    ViewData["Title"] = "Your Shopping Cart";
}

<h2>Shopping Cart</h2>

<table class="table align-middle">
    <thead>
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th style="width: 150px;">Quantity</th>
            <th>Total</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Product.Name</td>
                <td>$@item.Product.Price</td>
                <td>
                    <form asp-action="UpdateQuantity" method="post" class="d-flex">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="number" name="quantity" value="@item.Quantity" class="form-control form-control-sm me-1" min="1" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                    </form>
                </td>
                <td>$@(item.Quantity* item.Product.Price)</td>
                <td><a asp-action="Remove" asp-route-id="@item.Id" class="text-danger">Remove</a></td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between">
    <a asp-action="Clear" class="btn btn-outline-danger">Clear Cart</a>
    <div class="text-end">
        <h4>Subtotal: $@ViewBag.Total</h4>
        <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg">Checkout</a>
    </div>
</div>